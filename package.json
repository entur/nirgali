{
  "name": "nirgali",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/client": "4.1.9",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@internationalized/date": "3.12.1",
    "@mui/icons-material": "7.3.11",
    "@mui/material": "7.3.11",
    "@mui/x-date-pickers": "8.28.5",
    "@reduxjs/toolkit": "2.11.2",
    "date-fns": "4.1.0",
    "graphql": "16.14.0",
    "oidc-client-ts": "3.5.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-oidc-context": "3.3.1",
    "react-redux": "9.2.0",
    "react-router-dom": "7.15.0",
    "rxjs": "7.8.2"
  },
  "scripts": {
    "copy:config": "cp .github/environments/config-dev.json public/config.json",
    "prestart": "run-p --race copy:config",
    "start": "run-p --race start:react",
    "start:react": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --watch=false --coverage --coverage.reporter=lcov --reporter=vitest-sonar-reporter --outputFile.vitest-sonar-reporter=test-report.xml --reporter=default",
    "format": "prettier --write \"{src,config}/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "check": "prettier --check \"{src,config}/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "prepare": "husky install"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "{src,config}/**!(*node_modules)/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "singleQuote": true
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.0",
    "@vitest/coverage-v8": "4.1.5",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "16.4.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vite-plugin-svgr": "4.5.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5",
    "vitest-sonar-reporter": "3.0.0"
  }
}
